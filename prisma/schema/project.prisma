model Project {
  id                  String            @id @default(cuid())

  name                String
  description         String?

  ownerId String      @map("owner_id")
  owner               User @relation(fields: [ownerId], references: [id])

  tasks               Task[]

  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@map("projects")
}