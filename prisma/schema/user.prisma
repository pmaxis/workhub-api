model User {
  id                String           @id @default(cuid())

  email             String           @unique
  password          String

  lastName          String           @map("last_name")
  firstName         String           @map("first_name")
  thirdName         String?          @map("third_name")

  isActivated       Boolean          @default(false) @map("is_activated")

  sessions          Session[]
  roles             UserRole[]
  invitations       Invitation[]
  projects          Project[]
  tasks             Task[]
  notifications     Notification[]

  freelancerProfile FreelancerProfile?
  clientProfile     ClientProfile?

  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt      @map("updated_at")

  @@map("users")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model FreelancerProfile {
  id         String           @id @default(cuid())

  userId     String           @unique @map("user_id")
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  clients    ClientRelation[]

  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  @@map("freelancer_profiles")
}

model ClientProfile {
  id              String           @id @default(cuid())

  userId          String           @unique @map("user_id")
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyMembers  CompanyMember[]
  clientRelations ClientRelation[]

  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("client_profiles")
}

model ClientRelation {
  status              ClientStatus

  freelancerProfileId String            @map("freelancer_profile_id")
  freelancerProfile   FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)

  clientProfileId     String            @map("client_profile_id")
  clientProfile       ClientProfile     @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  companyId           String?           @map("company_id")
  company             Company?          @relation(fields: [companyId], references: [id])

  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@id([freelancerProfileId, clientProfileId])

  @@map("client_relationships")
}

enum ClientStatus {
  ACTIVE
  POTENTIAL
  ARCHIVE
}